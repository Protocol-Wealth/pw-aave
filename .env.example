# WalletConnect Cloud project ID — required for WalletConnect / RainbowKit.
# Get one free at https://cloud.reown.com
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: Alchemy API key for a higher-reliability Ethereum RPC.
# If omitted, falls back to viem's public RPC.
VITE_ALCHEMY_API_KEY=

# Feature flag: set to "true" to enable write flows (supply/withdraw/borrow/repay).
# Off by default in v1 — writes ship only after a dedicated review pass.
VITE_ENABLE_WRITES=false
